  "keyFeatures": [
    "Browse and filter pizza menu items with toppings and sizes",
    "Create and manage orders with custom pizza configurations",
    "Real-time delivery tracking and ETA estimation",
    "Customer profile management and saved addresses",
    "Webhook notifications for order status changes",
    "API key authentication with request signing"
  ],
  "publicApiSurface": [
    "GET /menu — list all menu items",
    "GET /menu/{id} — get a single menu item",
    "POST /orders — create a new order",
    "GET /orders/{id} — retrieve an order",
    "PATCH /orders/{id} — update an order",
    "DELETE /orders/{id} — cancel an order",
    "POST /customers — create a customer",
    "GET /customers/{id} — retrieve a customer",
    "PATCH /customers/{id} — update a customer",
    "GET /delivery/{order_id}/status — get delivery status",
    "GET /delivery/{order_id}/estimate — get delivery ETA"
  ]
}
